<Window
    x:Class="KJCDGCreator.Editor.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{Binding WindowTitle}"
    Width="1360"
    Height="720">
  <Window.Styles>
    <Style Selector="Button.action-button">
      <Setter Property="Foreground" Value="#F8F4EC" />
      <Setter Property="Background" Value="#243B4A" />
      <Setter Property="BorderBrush" Value="#243B4A" />
    </Style>
    <Style Selector="Button.action-button /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F8F4EC" />
      <Setter Property="Background" Value="#243B4A" />
    </Style>
    <Style Selector="Button.action-button:pointerover">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#35566A" />
      <Setter Property="BorderBrush" Value="#35566A" />
    </Style>
    <Style Selector="Button.action-button:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#35566A" />
    </Style>
    <Style Selector="Button.action-button:pressed">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#1C2D38" />
      <Setter Property="BorderBrush" Value="#1C2D38" />
    </Style>
    <Style Selector="Button.action-button:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#1C2D38" />
    </Style>

    <Style Selector="Button.action-button.save-button">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#9C5B2E" />
      <Setter Property="BorderBrush" Value="#9C5B2E" />
    </Style>
    <Style Selector="Button.action-button.save-button /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#9C5B2E" />
    </Style>
    <Style Selector="Button.action-button.save-button:pointerover">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#B56A36" />
      <Setter Property="BorderBrush" Value="#B56A36" />
    </Style>
    <Style Selector="Button.action-button.save-button:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#B56A36" />
    </Style>
    <Style Selector="Button.action-button.save-button:pressed">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#7D4924" />
      <Setter Property="BorderBrush" Value="#7D4924" />
    </Style>
    <Style Selector="Button.action-button.save-button:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#FFF8EE" />
      <Setter Property="Background" Value="#7D4924" />
    </Style>

    <Style Selector="TextBox.light-input">
      <Setter Property="Foreground" Value="#161310" />
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#B8AE9F" />
      <Setter Property="CaretBrush" Value="#161310" />
    </Style>
    <Style Selector="TextBox.light-input /template/ Border#border">
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#B8AE9F" />
    </Style>
    <Style Selector="TextBox.light-input /template/ ScrollViewer#PART_ScrollViewer">
      <Setter Property="Background" Value="#FFFDF8" />
    </Style>
    <Style Selector="TextBox.light-input:pointerover">
      <Setter Property="Foreground" Value="#161310" />
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#8D816F" />
      <Setter Property="CaretBrush" Value="#161310" />
    </Style>
    <Style Selector="TextBox.light-input:pointerover /template/ Border#border">
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#8D816F" />
    </Style>
    <Style Selector="TextBox.light-input:focus">
      <Setter Property="Foreground" Value="#161310" />
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#9C5B2E" />
      <Setter Property="CaretBrush" Value="#161310" />
    </Style>
    <Style Selector="TextBox.light-input:focus /template/ Border#border">
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#9C5B2E" />
    </Style>
    <Style Selector="TextBox.light-input:focus /template/ ScrollViewer#PART_ScrollViewer">
      <Setter Property="Background" Value="#FFFDF8" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <Border Padding="16" Background="#F6F2E8" CornerRadius="14">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Spacing="4">
          <TextBlock FontSize="28" FontWeight="Bold" Foreground="#1E1A16" Text="KJ CDG Creator" />
          <TextBlock Foreground="#4A4037" Text="Basic project editor for authoring karaoke metadata and lyrics." />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="action-button" Click="NewProject_Click" Content="New Project" />
          <Button Classes="action-button" Click="OpenProject_Click" Content="Open Project" />
          <Button Classes="action-button save-button" Click="SaveProject_Click" Content="Save Project" />
          <Button Classes="action-button save-button" Click="SaveProjectAs_Click" Content="Save Project As" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" ColumnDefinitions="320,*,360" Margin="0,18,0,18">
      <Border Padding="16" Background="#E7E0D2" CornerRadius="14">
        <StackPanel Spacing="12">
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#201A14" Text="Project Details" />
          <StackPanel Spacing="4">
            <TextBlock Foreground="#3D352D" Text="Title" />
            <TextBox Classes="light-input" Text="{Binding Title}" Watermark="Song title" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Foreground="#3D352D" Text="Artist" />
            <TextBox Classes="light-input" Text="{Binding Artist}" Watermark="Artist name" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Foreground="#3D352D" Text="Source MP3 Path" />
            <TextBox Classes="light-input" Text="{Binding SourceMp3Path}" Watermark="/path/to/source.mp3" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Foreground="#3D352D" Text="Project File" />
            <SelectableTextBlock Foreground="#2B241E" Text="{Binding ProjectPathDisplay}" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Foreground="#3D352D" Text="Validation" />
            <TextBlock Foreground="#2B241E" Text="{Binding ValidationMessage}" TextWrapping="Wrap" />
          </StackPanel>
          <Border Margin="0,8,0,0" Padding="12" Background="#F5EEE1" CornerRadius="10">
            <StackPanel Spacing="8">
              <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#201A14" Text="Tap Timing" />
              <StackPanel Spacing="2">
                <TextBlock Foreground="#3D352D" Text="Current Unit" />
                <TextBlock Foreground="#201A14" FontWeight="SemiBold" Text="{Binding CurrentUnitText}" TextWrapping="Wrap" />
              </StackPanel>
              <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                <TextBlock Foreground="#3D352D" Text="Progress" />
                <TextBlock Grid.Column="1" Margin="10,0,0,0" Foreground="#2B241E" Text="{Binding CurrentUnitProgress}" />
                <TextBlock Grid.Row="1" Foreground="#3D352D" Text="Counts" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,0,0,0" Foreground="#2B241E" Text="{Binding TimingCounts}" />
                <TextBlock Grid.Row="2" Foreground="#3D352D" Text="Audio Time" />
                <TextBlock Grid.Row="2" Grid.Column="1" Margin="10,0,0,0" Foreground="#2B241E" Text="{Binding CurrentAudioTimeDisplay}" />
              </Grid>
              <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                <Button Grid.Row="0" Classes="action-button" IsEnabled="{Binding CanPlayPause}" Click="PlayPauseTiming_Click" Content="{Binding PlayPauseButtonText}" />
                <Button Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Classes="action-button" IsEnabled="{Binding CanStop}" Click="StopTiming_Click" Content="Stop" />
                <Button Grid.Row="1" Margin="0,8,0,0" Classes="action-button save-button" IsEnabled="{Binding CanTap}" Click="TapTiming_Click" Content="Tap" />
                <Button Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" Classes="action-button" IsEnabled="{Binding CanUndo}" Click="UndoTiming_Click" Content="Undo" />
                <Button Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Classes="action-button" IsEnabled="{Binding CanResetTiming}" Click="ResetTiming_Click" Content="Reset Timing" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Margin="18,0,0,0" Padding="16" Background="#0F1E24" CornerRadius="14">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Spacing="6">
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F5E7C7" Text="Raw Lyrics Text" />
            <TextBlock Foreground="#D8D4CC" Text="Spaces create timing units automatically. Use | only to split inside a word, for example: Be|cause I'm hap|py." TextWrapping="Wrap" />
          </StackPanel>

          <TextBox
              Grid.Row="1"
              Margin="0,12,0,12"
              AcceptsReturn="True"
              Text="{Binding RawLyricsText}"
              Foreground="#F7F2E8"
              Background="#091115"
              CaretBrush="#F7F2E8"
              TextWrapping="Wrap"
              MinHeight="420"
              Watermark="Be|cause I'm hap|py&#10;Clap a|long" />

          <Border Grid.Row="2" Padding="12" Background="#17303A" CornerRadius="10">
            <StackPanel Spacing="4">
              <TextBlock Foreground="#F5E7C7" Text="Editing Notes" />
              <TextBlock Foreground="#D8D4CC" Text="This first editor focuses on project creation, open/save, and raw lyrics authoring. Timing, preview, and export screens will be added later." TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="2" Margin="18,0,0,0" Padding="16" Background="#11191E" CornerRadius="14">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Spacing="6">
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F5E7C7" Text="Karaoke Preview" />
            <TextBlock Foreground="#D8D4CC" Text="Live frame output from the current project state." />
          </StackPanel>

          <Border Grid.Row="1" Margin="0,12,0,12" Padding="12" Background="#060A0C" BorderBrush="#22333D" BorderThickness="1" CornerRadius="10">
            <Grid RowDefinitions="*,Auto">
              <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
              <TextBlock Grid.Row="1" Margin="0,12,0,0" Foreground="#D8D4CC" Text="{Binding PreviewStatusMessage}" TextWrapping="Wrap" />
            </Grid>
          </Border>

          <Border Grid.Row="2" Padding="12" Background="#17303A" CornerRadius="10">
            <StackPanel Spacing="4">
              <TextBlock Foreground="#F5E7C7" Text="Preview Notes" />
              <TextBlock Foreground="#D8D4CC" Text="The preview refreshes while playback runs and after timing changes, save/load, and project resets." TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Padding="12" Background="#F6F2E8" CornerRadius="12">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Foreground="#2B241E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        <TextBlock Grid.Column="1" Margin="16,0,0,0" Foreground="#4A4037" Text="{Binding HasUnsavedChanges, StringFormat=Unsaved changes: {0}}" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
